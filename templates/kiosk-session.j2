#!/bin/bash
# Sessão X11 disparada pelo LightDM como {{ kiosk_account_name }}.
# Scripts em /usr/local/lib/ebeg-kiosk pertencem a root (0755): executáveis,
# não graváveis por usuários comuns — reduz superfície de alteração indevida.

set -eu

export HOME="/home/{{ kiosk_account_name }}"
export USER="{{ kiosk_account_name }}"
export LOGNAME="{{ kiosk_account_name }}"
export XDG_CONFIG_HOME="${HOME}/.config"
export XDG_CACHE_HOME="${HOME}/.cache"
export XDG_DATA_HOME="${HOME}/.local/share"

# Limpeza de dados locais do Chromium a cada abertura de sessão (reforço além do --incognito).
rm -rf \
  "${HOME}/.cache/chromium" \
  "${HOME}/.config/chromium" \
  "${HOME}/.local/share/chromium" \
  2>/dev/null || true

mkdir -p "${XDG_CONFIG_HOME}" "${XDG_CACHE_HOME}" "${XDG_DATA_HOME}"

# Oculta cursor após curto período de inatividade (ajuda em telas touch / TV).
if command -v unclutter >/dev/null 2>&1; then
  unclutter -idle 0.1 -root &
fi

# Openbox leve: melhora empilhamento de janelas / tela cheia em hardware variado.
if command -v openbox >/dev/null 2>&1; then
  openbox &
  sleep 1
fi

exec "{{ kiosk_script_path }}"
